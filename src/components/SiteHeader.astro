---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/locations', label: 'Locations' },
  { href: '/social', label: 'Social' },
  { href: '/shop', label: 'Shop' },
  { href: '/start-a-swap', label: 'Start A Swap' },
  { href: '/about', label: 'About' }
];
---

<header class="site-header glass-frame">
  <div class="site-header__inner container">
    <a href="/" class="brand" aria-label="Austin Puzzle Exchange Home">
      <img src="/images/logo-min.png" alt="Austin Puzzle Exchange logo" loading="lazy" />
      <div>
        <span class="brand__eyebrow">Austin, Texas</span>
        <span class="brand__name">Austin Puzzle Exchange</span>
      </div>
    </a>

    <button id="menu-toggle" class="menu-toggle" type="button" aria-label="Toggle menu" aria-expanded="false">Menu</button>

    <nav id="site-nav" class="site-nav" aria-label="Primary">
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>

    <ThemeToggle />
  </div>
</header>

<script>
  const menuButton = document.querySelector('#menu-toggle');
  const nav = document.querySelector('#site-nav');

  menuButton?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('is-open');
    menuButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });

  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (window.innerWidth < 900) {
        nav.classList.remove('is-open');
        menuButton?.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>
