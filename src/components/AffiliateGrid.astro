---
const items = [
  {
    title: 'Jigsaw Puzzle Board',
    description: 'Portable board for sorting and saving work in progress.',
    href: 'https://amzn.to/2QJnAmf'
  },
  {
    title: 'Kid-Friendly Puzzles',
    description: 'Great starter options for younger puzzlers.',
    href: 'https://amzn.to/35F0i57'
  },
  {
    title: '3-D Puzzle Picks',
    description: 'Try a different challenge with dimensional builds.',
    href: 'https://amzn.to/2FDU8HR'
  }
];
---

<section class="affiliate-panel glass-card reveal-on-scroll" aria-labelledby="affiliate-title">
  <h2 id="affiliate-title">Support The Exchange</h2>
  <p class="affiliate-panel__intro">Optional affiliate links help offset site and maintenance costs.</p>
  <div class="affiliate-grid">
    {items.map((item) => (
      <article class="affiliate-item">
        <h3>{item.title}</h3>
        <p>{item.description}</p>
        <a class="button button--small" href={item.href} target="_blank" rel="sponsored noreferrer">View Item</a>
      </article>
    ))}
  </div>
  <div class="button-row">
    <a class="button button--secondary button--small" href="/shop">Open Full Puzzle Shop</a>
  </div>
  <p class="affiliate-panel__disclaimer">As an Amazon Associate, Austin Puzzle Exchange may earn from qualifying purchases.</p>
</section>
