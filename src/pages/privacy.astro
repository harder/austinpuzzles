---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy | Austin Puzzle Exchange"
  description="Privacy policy for Austin Puzzle Exchange website visitors and contact form users."
>
  <section class="container page-intro reveal-on-scroll">
    <p class="eyebrow">Privacy</p>
    <h1>Privacy Policy</h1>
    <p>Effective date: February 13, 2026.</p>
  </section>

  <section class="container section-stack">
    <article class="glass-card prose-block reveal-on-scroll">
      <h2>Information We Collect</h2>
      <p>We only collect personal information you voluntarily submit through forms, such as your email and message.</p>

      <h2>How We Use It</h2>
      <p>Submitted information is used to respond to your messages and help operate the local puzzle exchange.</p>

      <h2>Third-Party Services</h2>
      <p>
        This site may use third-party platforms including social embeds, map tiles, Cloudflare security tools,
        and external form processing providers.
      </p>

      <h2>Cookies and Browser Data</h2>
      <p>Basic browser data may be processed by third-party providers for security and rendering purposes.</p>

      <h2>Your Choices</h2>
      <p>If you want your submitted contact information deleted, email <a href="mailto:info@austinpuzzles.com">info@austinpuzzles.com</a>.</p>
    </article>
  </section>
</BaseLayout>
