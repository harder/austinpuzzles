# Optional: Worker API endpoints (recommended for caching + CORS control)
PUBLIC_SOCIAL_API_URL=https://austinpuzzles-worker.your-subdomain.workers.dev/api/social
PUBLIC_NEWS_API_URL=https://austinpuzzles-worker.your-subdomain.workers.dev/api/news

# Optional: Contact form provider override (defaults to FormSubmit)
PUBLIC_CONTACT_FORM_ACTION=https://formsubmit.co/info@austinpuzzles.com

# Optional: Turnstile widget + verification worker endpoint
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
PUBLIC_TURNSTILE_VERIFY_URL=https://austinpuzzles-worker.your-subdomain.workers.dev/api/verify-turnstile
